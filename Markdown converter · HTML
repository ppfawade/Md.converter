<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Markdown to Formatted Text Converter - Free Online Tool</title>
    <meta name="description" content="Convert markdown syntax to beautifully formatted text instantly. Free, simple, and privacy-focused markdown converter with live preview.">
    <meta name="keywords" content="markdown converter, markdown to text, markdown formatter, online markdown tool, markdown preview">
    <meta name="author" content="Markdown Converter">
    <meta property="og:title" content="Markdown to Formatted Text Converter">
    <meta property="og:description" content="Convert markdown syntax to beautifully formatted text instantly. Free, simple, and privacy-focused.">
    <meta property="og:type" content="website">
    <link rel="canonical" href="https://yoursite.com/markdown-converter">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #f5f5f7;
            --bg-secondary: #ffffff;
            --text-primary: #1d1d1f;
            --text-secondary: #6e6e73;
            --accent: #0071e3;
            --accent-hover: #0077ed;
            --border: rgba(0, 0, 0, 0.08);
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
            --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
            --radius: 18px;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        [data-theme="dark"] {
            --bg-primary: #1d1d1f;
            --bg-secondary: #2d2d30;
            --text-primary: #f5f5f7;
            --text-secondary: #a1a1a6;
            --accent: #0a84ff;
            --accent-hover: #409cff;
            --border: rgba(255, 255, 255, 0.1);
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
            --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.5);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            -webkit-font-smoothing: antialiased;
        }

        header {
            text-align: center;
            padding: 60px 20px 40px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
        }

        .toolbar {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            padding: 20px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
        }

        .toolbar-btn {
            background: var(--bg-primary);
            color: var(--text-primary);
            border: 1px solid var(--border);
            padding: 8px 16px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .toolbar-btn:hover {
            background: var(--bg-secondary);
            transform: translateY(-1px);
            box-shadow: var(--shadow-sm);
        }

        .toolbar-btn.active {
            background: var(--accent);
            color: white;
            border-color: var(--accent);
        }

        .kbd {
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 2px 6px;
            font-size: 11px;
            font-family: 'SF Mono', monospace;
            margin-left: 8px;
            color: var(--text-secondary);
        }

        h1 {
            font-size: clamp(28px, 5vw, 48px);
            font-weight: 600;
            letter-spacing: -0.02em;
            margin-bottom: 12px;
            background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            font-size: 17px;
            color: var(--text-secondary);
            font-weight: 400;
            max-width: 600px;
            margin: 0 auto;
        }

        main {
            flex: 1;
            padding: 40px 20px;
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
        }

        .converter-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 40px;
        }

        .panel {
            background: var(--bg-secondary);
            border-radius: var(--radius);
            padding: 28px;
            box-shadow: var(--shadow-md);
            display: flex;
            flex-direction: column;
            min-height: 500px;
            transition: var(--transition);
            border: 1px solid var(--border);
        }

        .panel:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
            transform: translateY(-2px);
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border);
        }

        .panel-title {
            font-size: 20px;
            font-weight: 600;
            letter-spacing: -0.01em;
        }

        .btn {
            background: var(--accent);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 2px 8px rgba(0, 113, 227, 0.2);
        }

        .btn:hover {
            background: var(--accent-hover);
            transform: scale(1.02);
            box-shadow: 0 4px 12px rgba(0, 113, 227, 0.3);
        }

        .btn:active {
            transform: scale(0.98);
        }

        .btn-secondary {
            background: var(--bg-primary);
            color: var(--text-primary);
            box-shadow: var(--shadow-sm);
        }

        .btn-secondary:hover {
            background: #e8e8ed;
            box-shadow: var(--shadow-md);
        }

        .input-area {
            flex: 1;
            width: 100%;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            font-size: 15px;
            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;
            line-height: 1.6;
            resize: none;
            background: var(--bg-primary);
            color: var(--text-primary);
            transition: var(--transition);
        }

        .input-area:focus {
            outline: none;
            border-color: var(--accent);
            background: var(--bg-secondary);
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
        }

        .output-area {
            flex: 1;
            width: 100%;
            padding: 16px;
            overflow-y: auto;
            background: var(--bg-primary);
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .output-area h1 {
            font-size: 32px;
            margin: 24px 0 16px;
            font-weight: 700;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .output-area h2 {
            font-size: 28px;
            margin: 20px 0 12px;
            font-weight: 600;
        }

        .output-area h3 {
            font-size: 24px;
            margin: 16px 0 10px;
            font-weight: 600;
        }

        .output-area h4 {
            font-size: 20px;
            margin: 14px 0 8px;
            font-weight: 600;
        }

        .output-area h5 {
            font-size: 18px;
            margin: 12px 0 6px;
            font-weight: 600;
        }

        .output-area h6 {
            font-size: 16px;
            margin: 10px 0 6px;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .output-area p {
            margin: 12px 0;
        }

        .output-area strong {
            font-weight: 600;
        }

        .output-area em {
            font-style: italic;
        }

        .output-area ul, .output-area ol {
            margin: 12px 0;
            padding-left: 28px;
        }

        .output-area li {
            margin: 6px 0;
        }

        .output-area a {
            color: var(--accent);
            text-decoration: none;
            transition: var(--transition);
        }

        .output-area a:hover {
            text-decoration: underline;
        }

        .output-area code {
            background: rgba(0, 0, 0, 0.05);
            padding: 2px 8px;
            border-radius: 6px;
            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;
            font-size: 14px;
        }

        .output-area pre {
            background: rgba(0, 0, 0, 0.05);
            padding: 16px;
            border-radius: 8px;
            overflow-x: auto;
            margin: 16px 0;
        }

        .output-area pre code {
            background: none;
            padding: 0;
        }

        .output-area blockquote {
            border-left: 4px solid var(--accent);
            padding-left: 20px;
            margin: 16px 0;
            color: var(--text-secondary);
            font-style: italic;
        }

        .output-area hr {
            border: none;
            border-top: 1px solid var(--border);
            margin: 24px 0;
        }

        .output-area del {
            text-decoration: line-through;
            color: var(--text-secondary);
        }

        .char-count {
            font-size: 13px;
            color: var(--text-secondary);
            text-align: right;
            margin-top: 8px;
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--text-secondary);
            text-align: center;
            padding: 40px;
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.3;
        }

        footer {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-secondary);
            font-size: 14px;
            border-top: 1px solid var(--border);
            background: var(--bg-secondary);
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--text-primary);
            color: white;
            padding: 16px 24px;
            border-radius: 12px;
            box-shadow: var(--shadow-md);
            opacity: 0;
            transform: translateY(-20px);
            transition: var(--transition);
            pointer-events: none;
            z-index: 1000;
        }

        .notification.show {
            opacity: 1;
            transform: translateY(0);
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            padding: 20px;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: var(--bg-secondary);
            border-radius: var(--radius);
            max-width: 700px;
            width: 100%;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: modalSlideIn 0.3s ease-out;
        }

        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: scale(0.95) translateY(20px);
            }
            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .modal-header {
            padding: 24px 28px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-title {
            font-size: 24px;
            font-weight: 600;
            letter-spacing: -0.02em;
        }

        .modal-close {
            background: var(--bg-primary);
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            color: var(--text-primary);
        }

        .modal-close:hover {
            background: var(--border);
            transform: rotate(90deg);
        }

        .modal-content {
            padding: 28px;
        }

        .syntax-group {
            margin-bottom: 24px;
        }

        .syntax-group h3 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .syntax-item {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 12px;
            padding: 12px;
            background: var(--bg-primary);
            border-radius: 8px;
            font-size: 14px;
        }

        .syntax-markdown {
            font-family: 'SF Mono', monospace;
            color: var(--accent);
        }

        .syntax-result {
            color: var(--text-secondary);
        }

        .template-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }

        .template-card {
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            cursor: pointer;
            transition: var(--transition);
        }

        .template-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
        }

        .template-name {
            font-weight: 600;
            font-size: 15px;
            margin-bottom: 4px;
        }

        .template-desc {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .shortcuts-grid {
            display: grid;
            gap: 12px;
        }

        .shortcut-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            background: var(--bg-primary);
            border-radius: 8px;
        }

        .shortcut-desc {
            font-size: 14px;
        }

        .shortcut-keys {
            display: flex;
            gap: 4px;
        }

        @media (max-width: 768px) {
            .converter-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .panel {
                min-height: 400px;
            }

            header {
                padding: 40px 20px 30px;
            }

            main {
                padding: 30px 16px;
            }

            .toolbar {
                gap: 8px;
                padding: 16px;
            }

            .toolbar-btn {
                padding: 6px 12px;
                font-size: 13px;
            }

            .kbd {
                display: none;
            }

            .modal {
                max-width: 100%;
                max-height: 90vh;
            }

            .syntax-item {
                grid-template-columns: 1fr;
                gap: 8px;
            }

            .template-grid {
                grid-template-columns: 1fr;
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .panel {
            animation: fadeIn 0.6s ease-out;
        }

        .panel:nth-child(2) {
            animation-delay: 0.1s;
        }
    </style>
</head>
<body>
    <header>
        <h1>Markdown Converter</h1>
        <p class="subtitle">Transform markdown into beautifully formatted text, instantly</p>
    </header>

    <div class="toolbar">
        <button class="toolbar-btn" id="templatesBtn">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                <path d="M2 2h12a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1zm0 1v2h12V3H2zm0 3v7h5V6H2zm6 0v7h6V6H8z"/>
            </svg>
            Templates
        </button>
        <button class="toolbar-btn" id="guideBtn">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 13A6 6 0 1 1 8 2a6 6 0 0 1 0 12zm.5-9.5a.5.5 0 0 0-1 0v4a.5.5 0 0 0 1 0v-4zm0 6a.5.5 0 1 0-1 0 .5.5 0 0 0 1 0z"/>
            </svg>
            Syntax Guide
        </button>
        <button class="toolbar-btn" id="shortcutsBtn">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H2zm3.5 3h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zm0 3h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zm0 3h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1z"/>
            </svg>
            Shortcuts<span class="kbd">?</span>
        </button>
        <button class="toolbar-btn" id="themeBtn">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 1v12a6 6 0 0 0 0-12z"/>
            </svg>
            Dark Mode
        </button>
    </div>

    <main>
        <div class="converter-grid">
            <div class="panel">
                <div class="panel-header">
                    <h2 class="panel-title">Markdown Input</h2>
                    <button class="btn btn-secondary" id="pasteBtn" title="Paste from clipboard">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                            <path d="M5.5 2A1.5 1.5 0 0 0 4 3.5v9A1.5 1.5 0 0 0 5.5 14h5a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 10.5 2h-5zM5 3.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-5a.5.5 0 0 1-.5-.5v-9z"/>
                        </svg>
                        Paste
                    </button>
                </div>
                <textarea 
                    class="input-area" 
                    id="markdownInput" 
                    placeholder="# Start typing markdown here...

Try these examples:
- **Bold text**
- *Italic text*
- [Link](https://example.com)
- `inline code`

## Headers work too!

> Blockquotes look great

1. Ordered lists
2. Are supported"
                    spellcheck="false"
                ></textarea>
                <div class="char-count" id="charCount">0 characters</div>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <h2 class="panel-title">Formatted Output</h2>
                    <button class="btn" id="copyBtn" title="Copy to clipboard">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                            <path d="M4 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H6zM2 5a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1h1v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1v1H2z"/>
                        </svg>
                        Copy Output
                    </button>
                </div>
                <div class="output-area" id="output">
                    <div class="empty-state">
                        <div class="empty-icon">✨</div>
                        <p>Your formatted text will appear here</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer>
        <p>Privacy-first • No data collection • Works offline • <strong>One file, zero complexity</strong></p>
        <p style="margin-top: 8px; font-size: 13px; opacity: 0.7;">Enhanced with Dark Mode • Templates • Syntax Guide • Keyboard Shortcuts</p>
    </footer>

    <div class="notification" id="notification"></div>

    <!-- Syntax Guide Modal -->
    <div class="modal-overlay" id="guideModal">
        <div class="modal">
            <div class="modal-header">
                <h2 class="modal-title">Markdown Syntax Guide</h2>
                <button class="modal-close" onclick="closeModal('guideModal')">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854z"/>
                    </svg>
                </button>
            </div>
            <div class="modal-content">
                <div class="syntax-group">
                    <h3>Headers</h3>
                    <div class="syntax-item">
                        <div class="syntax-markdown"># Heading 1</div>
                        <div class="syntax-result">Largest heading</div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">## Heading 2</div>
                        <div class="syntax-result">Second level</div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">### Heading 3</div>
                        <div class="syntax-result">Third level</div>
                    </div>
                </div>

                <div class="syntax-group">
                    <h3>Text Styling</h3>
                    <div class="syntax-item">
                        <div class="syntax-markdown">**bold text**</div>
                        <div class="syntax-result"><strong>bold text</strong></div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">*italic text*</div>
                        <div class="syntax-result"><em>italic text</em></div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">~~strikethrough~~</div>
                        <div class="syntax-result"><del>strikethrough</del></div>
                    </div>
                </div>

                <div class="syntax-group">
                    <h3>Lists</h3>
                    <div class="syntax-item">
                        <div class="syntax-markdown">- Item one<br>- Item two</div>
                        <div class="syntax-result">Bullet list</div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">1. First<br>2. Second</div>
                        <div class="syntax-result">Numbered list</div>
                    </div>
                </div>

                <div class="syntax-group">
                    <h3>Links & Code</h3>
                    <div class="syntax-item">
                        <div class="syntax-markdown">[Link text](url)</div>
                        <div class="syntax-result">Creates hyperlink</div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">`inline code`</div>
                        <div class="syntax-result"><code>inline code</code></div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">```<br>code block<br>```</div>
                        <div class="syntax-result">Multi-line code</div>
                    </div>
                </div>

                <div class="syntax-group">
                    <h3>Other</h3>
                    <div class="syntax-item">
                        <div class="syntax-markdown">> Quote text</div>
                        <div class="syntax-result">Blockquote</div>
                    </div>
                    <div class="syntax-item">
                        <div class="syntax-markdown">---</div>
                        <div class="syntax-result">Horizontal line</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Shortcuts Modal -->
    <div class="modal-overlay" id="shortcutsModal">
        <div class="modal">
            <div class="modal-header">
                <h2 class="modal-title">Keyboard Shortcuts</h2>
                <button class="modal-close" onclick="closeModal('shortcutsModal')">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854z"/>
                    </svg>
                </button>
            </div>
            <div class="modal-content">
                <div class="shortcuts-grid">
                    <div class="shortcut-item">
                        <span class="shortcut-desc">Copy output</span>
                        <div class="shortcut-keys">
                            <span class="kbd">Ctrl</span><span class="kbd">Shift</span><span class="kbd">C</span>
                        </div>
                    </div>
                    <div class="shortcut-item">
                        <span class="shortcut-desc">Paste input</span>
                        <div class="shortcut-keys">
                            <span class="kbd">Ctrl</span><span class="kbd">Shift</span><span class="kbd">V</span>
                        </div>
                    </div>
                    <div class="shortcut-item">
                        <span class="shortcut-desc">Clear input</span>
                        <div class="shortcut-keys">
                            <span class="kbd">Ctrl</span><span class="kbd">Shift</span><span class="kbd">X</span>
                        </div>
                    </div>
                    <div class="shortcut-item">
                        <span class="shortcut-desc">Toggle dark mode</span>
                        <div class="shortcut-keys">
                            <span class="kbd">Ctrl</span><span class="kbd">Shift</span><span class="kbd">D</span>
                        </div>
                    </div>
                    <div class="shortcut-item">
                        <span class="shortcut-desc">Show syntax guide</span>
                        <div class="shortcut-keys">
                            <span class="kbd">?</span>
                        </div>
                    </div>
                    <div class="shortcut-item">
                        <span class="shortcut-desc">Show shortcuts</span>
                        <div class="shortcut-keys">
                            <span class="kbd">Ctrl</span><span class="kbd">?</span>
                        </div>
                    </div>
                    <div class="shortcut-item">
                        <span class="shortcut-desc">Close modal</span>
                        <div class="shortcut-keys">
                            <span class="kbd">Esc</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Templates Modal -->
    <div class="modal-overlay" id="templatesModal">
        <div class="modal">
            <div class="modal-header">
                <h2 class="modal-title">Markdown Templates</h2>
                <button class="modal-close" onclick="closeModal('templatesModal')">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854z"/>
                    </svg>
                </button>
            </div>
            <div class="modal-content">
                <div class="template-grid" id="templateGrid"></div>
            </div>
        </div>
    </div>

    <script>
        const markdownInput = document.getElementById('markdownInput');
        const output = document.getElementById('output');
        const copyBtn = document.getElementById('copyBtn');
        const pasteBtn = document.getElementById('pasteBtn');
        const charCount = document.getElementById('charCount');
        const notification = document.getElementById('notification');
        const themeBtn = document.getElementById('themeBtn');
        const guideBtn = document.getElementById('guideBtn');
        const shortcutsBtn = document.getElementById('shortcutsBtn');
        const templatesBtn = document.getElementById('templatesBtn');

        // Templates data
        const templates = {
            blog: {
                name: "Blog Post",
                desc: "Article structure",
                content: `# Article Title

## Introduction
Start with a compelling hook...

## Main Points
- Key point one
- Key point two
- Key point three

## Conclusion
Wrap up your thoughts...

**Author:** Your Name`
            },
            readme: {
                name: "README",
                desc: "Project documentation",
                content: `# Project Name

> A brief description of your project

## Features
- Feature one
- Feature two
- Feature three

## Installation
\`\`\`
npm install package-name
\`\`\`

## Usage
\`\`\`
const example = require('package-name');
\`\`\`

## License
MIT`
            },
            notes: {
                name: "Meeting Notes",
                desc: "Quick meeting template",
                content: `# Meeting Notes - [Date]

## Attendees
- Person 1
- Person 2

## Agenda
1. Topic one
2. Topic two
3. Topic three

## Discussion
- Main point discussed
- Decision made

## Action Items
- [ ] Task for person 1
- [ ] Task for person 2

## Next Meeting
**Date:** TBD`
            },
            email: {
                name: "Email Draft",
                desc: "Professional email",
                content: `**Subject:** [Topic]

**To:** [Recipient]

**Hi [Name],**

I hope this message finds you well.

[Main message content]

**Key points:**
- Point one
- Point two

Please let me know if you have any questions.

**Best regards,**
[Your Name]`
            },
            list: {
                name: "Task List",
                desc: "To-do checklist",
                content: `# Tasks for [Project/Date]

## High Priority
- [ ] Important task 1
- [ ] Important task 2

## Medium Priority
- [ ] Task 3
- [ ] Task 4

## Low Priority
- [ ] Task 5
- [ ] Task 6

## Completed
- [x] Finished task`
            },
            tutorial: {
                name: "Tutorial",
                desc: "Step-by-step guide",
                content: `# How to [Topic]

## Prerequisites
- Requirement 1
- Requirement 2

## Step 1: [Action]
Detailed explanation...

\`\`\`
code example
\`\`\`

## Step 2: [Action]
More details...

## Step 3: [Action]
Final steps...

## Troubleshooting
> Common issue: Solution

## Conclusion
You've successfully learned...`
            }
        };

        // Theme handling
        function toggleTheme() {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            themeBtn.classList.toggle('active');
            showNotification(`${newTheme === 'dark' ? '🌙' : '☀️'} ${newTheme === 'dark' ? 'Dark' : 'Light'} mode enabled`);
        }

        // Load saved theme
        const savedTheme = localStorage.getItem('theme') || 'light';
        if (savedTheme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            themeBtn.classList.add('active');
        }

        themeBtn.addEventListener('click', toggleTheme);

        // Modal functions
        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // Make closeModal available globally
        window.closeModal = closeModal;

        // Close modals on overlay click
        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) {
                    closeModal(overlay.id);
                }
            });
        });

        // Templates
        function loadTemplates() {
            const grid = document.getElementById('templateGrid');
            grid.innerHTML = '';
            
            Object.keys(templates).forEach(key => {
                const template = templates[key];
                const card = document.createElement('div');
                card.className = 'template-card';
                card.innerHTML = `
                    <div class="template-name">${template.name}</div>
                    <div class="template-desc">${template.desc}</div>
                `;
                card.addEventListener('click', () => {
                    markdownInput.value = template.content;
                    convertMarkdown(template.content);
                    updateCharCount();
                    closeModal('templatesModal');
                    showNotification(`✓ ${template.name} template loaded`);
                });
                grid.appendChild(card);
            });
        }

        // Button handlers
        guideBtn.addEventListener('click', () => openModal('guideModal'));
        shortcutsBtn.addEventListener('click', () => openModal('shortcutsModal'));
        templatesBtn.addEventListener('click', () => {
            loadTemplates();
            openModal('templatesModal');
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            // Ctrl/Cmd + Shift + C - Copy output
            if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'C') {
                e.preventDefault();
                copyBtn.click();
            }
            
            // Ctrl/Cmd + Shift + V - Paste input
            if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'V') {
                e.preventDefault();
                pasteBtn.click();
            }
            
            // Ctrl/Cmd + Shift + X - Clear input
            if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'X') {
                e.preventDefault();
                markdownInput.value = '';
                convertMarkdown('');
                updateCharCount();
                showNotification('✓ Input cleared');
            }
            
            // Ctrl/Cmd + Shift + D - Toggle dark mode
            if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'D') {
                e.preventDefault();
                toggleTheme();
            }
            
            // ? - Show syntax guide
            if (e.key === '?' && !e.ctrlKey && !e.metaKey && document.activeElement !== markdownInput) {
                e.preventDefault();
                openModal('guideModal');
            }
            
            // Ctrl/Cmd + ? - Show shortcuts
            if ((e.ctrlKey || e.metaKey) && e.key === '?') {
                e.preventDefault();
                openModal('shortcutsModal');
            }
            
            // Escape - Close modals
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay.active').forEach(modal => {
                    closeModal(modal.id);
                });
            }
        });

        function showNotification(message) {
            notification.textContent = message;
            notification.classList.add('show');
            setTimeout(() => {
                notification.classList.remove('show');
            }, 2000);
        }

        function convertMarkdown(markdown) {
            if (!markdown.trim()) {
                output.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-icon">✨</div>
                        <p>Your formatted text will appear here</p>
                    </div>
                `;
                return;
            }

            let html = markdown;

            // Headers
            html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
            html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
            html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
            html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
            html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
            html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');

            // Horizontal rules
            html = html.replace(/^(?:---|\*\*\*|___)\s*$/gm, '<hr>');

            // Code blocks
            html = html.replace(/```([^`]+)```/g, '<pre><code>$1</code></pre>');

            // Blockquotes
            html = html.replace(/^>\s+(.+)$/gm, '<blockquote>$1</blockquote>');

            // Bold
            html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/__(.+?)__/g, '<strong>$1</strong>');

            // Italic
            html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
            html = html.replace(/_(.+?)_/g, '<em>$1</em>');

            // Strikethrough
            html = html.replace(/~~(.+?)~~/g, '<del>$1</del>');

            // Links
            html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');

            // Inline code
            html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

            // Unordered lists
            html = html.replace(/^[-*+]\s+(.+)$/gm, '<li>$1</li>');
            html = html.replace(/(<li>.*<\/li>)/s, function(match) {
                return '<ul>' + match + '</ul>';
            });

            // Ordered lists
            html = html.replace(/^\d+\.\s+(.+)$/gm, '<li>$1</li>');
            html = html.replace(/(<li>.*<\/li>)/s, function(match) {
                if (!match.includes('<ul>')) {
                    return '<ol>' + match + '</ol>';
                }
                return match;
            });

            // Paragraphs
            html = html.split('\n\n').map(para => {
                para = para.trim();
                if (!para) return '';
                if (para.startsWith('<h') || para.startsWith('<ul') || 
                    para.startsWith('<ol') || para.startsWith('<pre') || 
                    para.startsWith('<blockquote') || para.startsWith('<hr')) {
                    return para;
                }
                return '<p>' + para.replace(/\n/g, '<br>') + '</p>';
            }).join('\n');

            output.innerHTML = html;
        }

        function updateCharCount() {
            const count = markdownInput.value.length;
            charCount.textContent = `${count.toLocaleString()} character${count !== 1 ? 's' : ''}`;
        }

        markdownInput.addEventListener('input', () => {
            convertMarkdown(markdownInput.value);
            updateCharCount();
        });

        copyBtn.addEventListener('click', async () => {
            const text = output.innerText;
            if (!text || text.includes('Your formatted text will appear here')) {
                showNotification('Nothing to copy yet!');
                return;
            }
            try {
                await navigator.clipboard.writeText(text);
                showNotification('✓ Copied to clipboard!');
            } catch (err) {
                showNotification('Failed to copy. Please try again.');
            }
        });

        pasteBtn.addEventListener('click', async () => {
            try {
                const text = await navigator.clipboard.readText();
                markdownInput.value = text;
                convertMarkdown(text);
                updateCharCount();
                showNotification('✓ Pasted from clipboard!');
            } catch (err) {
                showNotification('Failed to paste. Please allow clipboard access.');
            }
        });

        // Initialize
        updateCharCount();
    </script>
</body>
</html>
